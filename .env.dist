# ===================================================================================
# .env.dist — Default configuration template (based on the SMALL sizing profile)
# ===================================================================================
# Copy this file to .env and fill in your project-specific values.
# Run 'make init' to set this up automatically.
#
# Sizing profiles (apply with 'make size-small/medium/large'):
#
#   PROFILE | APP CPUS/RAM | PHP MEM/OPCACHE | FPM CHILDREN | DB CPUS/RAM | DB BUFFER POOL | DB MAX CONN
#   --------+--------------+-----------------+--------------+-------------+----------------+------------
#   SMALL   | 0.5 / 256M   | 128M / 128MB    | 10 (dynamic) | 1.0 / 512M  | 128M           | 50
#   MEDIUM  | 1.0 / 512M   | 256M / 256MB    | 25 (dynamic) | 2.0 / 1.0G  | 256M           | 100
#   LARGE   | 2.0 / 1.0G   | 512M / 512MB    | 50 (dynamic) | 4.0 / 3.0G  | 1.0G (2 inst)  | 300
# ===================================================================================

# ===================================================================================
# 1. System & Stack Identification
# ===================================================================================

# Unique name for the project (lowercase alphanumeric).
# Used for container names, networks, and Traefik router domains.
PROJECT_NAME=project

# Unique 3-digit numeric ID for the project (e.g., 001, 999).
# Prevents port collisions by mapping DB to 33${PROJECT_ID} and SFTP to 22${PROJECT_ID}.
PROJECT_ID=999

# System timezone shared by the host, OS, PHP, and MariaDB containers.
TZ=Europe/Madrid

# UID (User ID) of the host developer or deployer user.
# Maps www-data inside the container to this UID to prevent file ownership conflicts on shared volumes.
USER_ID=1000

# GID (Group ID) of the host developer or deployer group.
# Maps www-data inside the container to this GID to prevent folder permission conflicts.
GROUP_ID=1000

# ===================================================================================
# 2. Application Environment Settings
# ===================================================================================

# Execution environment (production or development).
# - production: High security, onscreen errors disabled, strict OPcache compilation caching.
# - development: Auto-compiling code changes, error logging, and Xdebug enabled.
APP_ENV=development

# List of optional profiles to enable (comma-separated).
# By default, only 'app' and 'db' are started.
# Available optional profiles:
# - cron:  Starts a dedicated CLI container to execute cron tasks.
# - sftp:  Starts a secure FTP file transfer container mapped to docroot.
# - redis: Starts a high-performance in-memory Valkey (Redis-compatible) cache container.
# Example: COMPOSE_PROFILES=cron,sftp,redis
COMPOSE_PROFILES=

# Entrypoint log output verbosity for the serversideup base script (warn | info | debug).
LOG_OUTPUT_LEVEL=warn

# ===================================================================================
# 3. Apache Web Server Configuration
# ===================================================================================

# Path to the public folder containing index.php. Inside Docker, this points to Apache's document root.
APACHE_DOCUMENT_ROOT=/var/www/html/public

# Maximum time (seconds) Apache waits for PHP-FPM to respond. Default is 300s (5 min).
# WARNING: In production, long timeouts can block FPM slots. With PM_MAX_CHILDREN=10,
# just 10 hung requests at 1800s will cause a complete 30-minute web server freeze.
APACHE_PROXY_TIMEOUT=300

# Web server log verbosity level (warn | error | info | debug).
APACHE_LOG_LEVEL=warn

# Limits simultaneous Apache worker threads. Must be kept aligned with PHP_FPM_PM_MAX_CHILDREN.
# (SMALL: 10, MEDIUM: 25, LARGE: 50)
APACHE_MAX_REQUEST_WORKERS=10

# ===================================================================================
# 4. PHP Engine Configuration
# ===================================================================================

# Target PHP version for serversideup/php image (e.g., 5.6, 7.4, 8.1, 8.2).
PHP_VERSION=7.4

# Max memory allocated per script execution. Increase for large report generation/exports.
# (SMALL: 128M, MEDIUM: 256M, LARGE: 512M)
PHP_MEMORY_LIMIT=128M

# Max execution time (seconds) for scripts. Set to 0 for unlimited (CLI only).
PHP_MAX_EXECUTION_TIME=300

# Maximum size of POST request payload Apache/PHP accepts.
PHP_POST_MAX_SIZE=50M

# Maximum size for individual uploaded files. Must be <= PHP_POST_MAX_SIZE.
PHP_UPLOAD_MAX_FILE_SIZE=10M

# Maximum input variables (GET/POST/Cookies).
# ZF1 backoffice forms with massive grids or multi-selects often hit the default 1000 limit.
PHP_MAX_INPUT_VARS=3000

# Active error reporting level for PHP interpreter.
PHP_ERROR_REPORTING="E_ALL & ~E_WARNING & ~E_NOTICE & ~E_DEPRECATED & ~E_STRICT"

# Explicit onscreen error override. By default, error display is managed dynamically based on APP_ENV
# (safely routing errors to log files rather than browser output). Uncomment to override.
#PHP_DISPLAY_ERRORS=Off
#PHP_DISPLAY_STARTUP_ERRORS=Off

# Active Xdebug mode (off | debug | develop | coverage | profile | trace).
# Must be set to 'off' in production to guarantee zero performance overhead.
PHP_XDEBUG_MODE=off

# ===================================================================================
# 5. PHP Performance Tuning (OPcache & Realpath)
# ===================================================================================

# OPcache memory allocation in MB (SMALL: 128, MEDIUM: 256, LARGE: 512+).
PHP_OPCACHE_MEMORY_CONSUMPTION=128

# OPcache buffer for immutable compiler strings in MB. Reduces RAM fragmentation.
# (SMALL: 16, MEDIUM: 32, LARGE: 64)
PHP_OPCACHE_INTERNED_STRINGS_BUFFER=16

# Maximum number of PHP files allowed in the OPcache keyspace.
PHP_OPCACHE_MAX_ACCELERATED_FILES=20000

# Enable OPcache Huge Code Pages (0=off, 1=on). Reduces TLB cache misses on CPU.
# Requires Transparent Huge Pages (THP) enabled on the host server kernel.
PHP_OPCACHE_HUGE_CODE_PAGES=0

# Time-to-Live (seconds) for PHP's realpath resolution cache.
# Large ZF1 applications resolve hundreds of paths per request. High values prevent redundant disk lookups.
# (Recommended: 7200 for production. Reduce to 60-120 in development if folder structures change frequently)
PHP_REALPATH_CACHE_TTL=7200

# OPcache script timestamp validation.
# In production, set to 0 (never check files, code is immutable). In development, set to 1.
# Managed dynamically based on APP_ENV. Uncomment to override manual behaviour.
#PHP_OPCACHE_VALIDATE_TIMESTAMPS=0
#PHP_OPCACHE_REVALIDATE_FREQ=60

# ===================================================================================
# 6. PHP-FPM Pool Configuration
# ===================================================================================

# Process manager control style (dynamic | static | ondemand).
# - dynamic: Scales workers dynamically based on traffic demand (recommended for production).
# - static: Fixed number of workers (fastest, high RAM utilization).
# - ondemand: Spawns workers only when requests arrive (cold start latency, low idle RAM usage).
PHP_FPM_PM_CONTROL=dynamic

# Maximum concurrent PHP-FPM child workers. Must align with APACHE_MAX_REQUEST_WORKERS.
# (SMALL: 10, MEDIUM: 25, LARGE: 50)
PHP_FPM_PM_MAX_CHILDREN=10

# Number of PHP-FPM workers started on initialization. Only used when PM is dynamic.
# (SMALL: 3, MEDIUM: 8, LARGE: 15)
PHP_FPM_PM_START_SERVERS=3

# Minimum number of idle workers kept alive. Only used when PM is dynamic.
# (SMALL: 2, MEDIUM: 5, LARGE: 10)
PHP_FPM_PM_MIN_SPARE_SERVERS=2

# Maximum number of idle workers kept alive. Only used when PM is dynamic.
# (SMALL: 5, MEDIUM: 15, LARGE: 30)
PHP_FPM_PM_MAX_SPARE_SERVERS=5

# Recycles workers after N requests to prevent slow memory leaks from legacy ZF1 codebases.
# (Recommended: 500. Set between 200 and 1000 depending on framework stability)
PHP_FPM_PM_MAX_REQUESTS=500

# Logs slow PHP-FPM scripts exceeding this threshold. Set to 0 to disable.
# Crucial diagnostic setting for tracing database bottlenecks in production.
PHP_FPM_SLOWLOG_TIMEOUT=10s

# ===================================================================================
# 7. MariaDB Database Connection
# ===================================================================================

# Hostname for database container is locked to the service name 'db' inside docker-compose.
# Database name.
DB_NAME=dbname

# Database username.
DB_USER=dbuser

# Database password.
DB_PASS=dbpass

# Root user database password (strictly used for migrations and administration).
DB_ROOT_PASS=dbrootpass

# Network interface IP address the database port (33${PROJECT_ID}) binds on the host.
# - 172.17.0.1: Binds to docker bridge interface so dockerized services can discover the DB.
# - 127.0.0.1: Restricts connections to host localhost only.
# - 0.0.0.0: Exposes port to the external network (requires robust external host firewall).
DB_BIND_IP=172.17.0.1

# ===================================================================================
# 8. MariaDB Resource & Performance Tuning
# ===================================================================================

# Strict CPU allocation limit for MariaDB container.
# Database queries require more CPU overhead than PHP scripts during execution peaks.
DB_CPUS=1.0

# Strict physical RAM limit allocated to MariaDB container.
DB_MEMORY=512M

# RAM reservation allocated to database on startup.
DB_MEMORY_RESERVATION=128M

# Maximum simultaneous DB client connections.
# Rule of thumb: Must be >= (PHP_FPM_PM_MAX_CHILDREN * 3) because ZF1 apps can open multiple connections.
# (SMALL: 50, MEDIUM: 100, LARGE: 300)
DB_MAX_CONNECTIONS=50

# Cache size (bytes) for InnoDB data and index indexes. 
# Single most critical performance variable. Set to 50-70% of DB_MEMORY.
# (SMALL: 128M, MEDIUM: 256M, LARGE: 1.0G)
DB_INNODB_BUFFER_POOL_SIZE=128M

# Split buffer pool into N separate instances. Keeps lock contention low for pool sizes >= 1GB.
# Set to 1 for smaller buffer pools.
DB_INNODB_BUFFER_POOL_INSTANCES=1

# InnoDB redo transaction log file size. Typically set to 25% of DB_INNODB_BUFFER_POOL_SIZE.
DB_INNODB_LOG_FILE_SIZE=32M

# InnoDB transaction flush durability behavior.
# - 1: Safe ACID compliance. Writes and flushes logs to disk at every commit.
# - 2: High performance. Flushes logs once per second. Risks losing 1s of data on host crash.
# (Recommended: 2 in dev/small apps, 1 in production where data loss is intolerable)
DB_INNODB_FLUSH_LOG_AT_TRX_COMMIT=2

# Number of open table file descriptors cached in RAM. Must be higher for databases with thousands of tables.
DB_TABLE_OPEN_CACHE=2000

# Number of table metadata schemas cached in memory (stores parsed table definitions).
DB_TABLE_DEFINITION_CACHE=1400

# ===================================================================================
# 9. SFTP Service Configuration
# ===================================================================================

# Username for SFTP file uploads.
SFTP_USER=sftpuser

# Password for SFTP user.
SFTP_PASS=sftppass

# Network interface IP address the SFTP port (22${PROJECT_ID}) binds on the host.
# - 127.0.0.1: Restricts SFTP access to localhost only (safe default).
# - 0.0.0.0: Exposes port to the external network (requires robust external host firewall).
SFTP_BIND_IP=127.0.0.1

# ===================================================================================
# 10. Infrastructure Resource Limits & Orchestration
# ===================================================================================

# --- App Container Resource Limits ---
# Strict CPU allocation limit for the main web application container.
APP_CPUS=0.5

# Strict RAM allocation limit for the web application container.
APP_MEMORY=256M

# Web container RAM reservation allocated on startup.
APP_MEMORY_RESERVATION=64M

# Size of the high-performance temporary in-memory tmpfs volume mounted at /var/www/html/tmp.
# (Recommended: minimum 128M to avoid system disk storage slowing down sessions and caching)
APP_TMPFS_SIZE=128M

# --- Cron Container Resource Limits ---
# Controls limits for the lightweight CLI process scheduler.
CRON_CPUS=0.1
CRON_MEMORY=128M
CRON_MEMORY_RESERVATION=32M

# --- Orchestration Healthcheck Settings ---
# Time interval between background service health checks.
HEALTHCHECK_INTERVAL=60s

# Initial grace period allowed for PHP/DB containers to boot before health checks fail.
HEALTHCHECK_START_PERIOD=30s